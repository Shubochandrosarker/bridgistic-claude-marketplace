{
  "name": "bridgistic-mcp-server",
  "version": "1.0.0",
  "description": "MCP server that bridges Claude (Desktop / Code) to any WordPress site running the free Bridgistic plugin. HMAC-signed, scope-aware, local-first.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bridgistic-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild dist/index.js --bundle --platform=node --target=node20 --format=cjs --outfile=../plugins/bridgistic/server/index.js --log-level=warning",
    "validate": "tsc --noEmit",
    "start": "node dist/index.js",
    "start:http": "TRANSPORT=http node dist/index.js",
    "dev": "tsc --watch",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "test": "node evals/contract.test.mjs && node evals/integration.test.mjs",
    "test:contract": "node evals/contract.test.mjs",
    "test:integration": "node evals/integration.test.mjs",
    "eval:selection": "node evals/run-tool-selection.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "esbuild": "^0.24.0"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "Shuvo Sarker (WordPressistic)",
  "license": "GPL-2.0-or-later",
  "homepage": "https://github.com/Shubochandrosarker/bridgistic-claude-marketplace",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shubochandrosarker/bridgistic-claude-marketplace.git"
  },
  "bugs": {
    "url": "https://github.com/Shubochandrosarker/bridgistic-claude-marketplace/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "wordpress",
    "claude",
    "ai",
    "hmac",
    "automation",
    "wordpressistic"
  ]
}

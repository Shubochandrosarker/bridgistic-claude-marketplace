# Bridgistic MCP server configuration
# Copy to .env and fill in your values, or set these directly in the
# `env` block of your Claude Desktop / Claude Code MCP config.
# NEVER commit a file containing real keys.

# --- Single-site connection (most users) -------------------------------------
# Your site URL exactly as shown in WP Admin -> Settings -> General.
BRIDGISTIC_SITE_URL=https://example.com

# Key credentials from WP Admin -> Bridgistic -> Claude Setup.
# The secret is shown ONCE at creation. If you lost it, rotate the key.
BRIDGISTIC_KEY_ID=your_key_id
BRIDGISTIC_KEY_SECRET=your_key_secret

# --- Multi-site registry (optional) ------------------------------------------
# Absolute path to a JSON file mapping aliases to connections.
# See connections.example.json. Can be combined with the single-site vars.
# BRIDGISTIC_CONNECTIONS=/absolute/path/to/connections.json

# --- Transport ----------------------------------------------------------------
# stdio (default) is what Claude Desktop and Claude Code use.
# http is for local development only; without BRIDGISTIC_HTTP_TOKEN it binds
# to 127.0.0.1 and refuses non-loopback requests.
BRIDGISTIC_TRANSPORT=stdio

# --- Logging -------------------------------------------------------------------
# error | warn | info | debug   (stderr only; secrets are never logged)
BRIDGISTIC_LOG_LEVEL=info
